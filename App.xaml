<Application x:Class="Newton4thGui.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>


        <!-- Display panel (mimics PPA5500 LCD: black bg, yellow text) -->
        <SolidColorBrush x:Key="DisplayBg"      Color="#070707"/>
        <SolidColorBrush x:Key="DisplayFg"      Color="#FFD23F"/>
        <SolidColorBrush x:Key="DisplayDim"     Color="#B89020"/>
        <SolidColorBrush x:Key="DisplayHeader"  Color="#FF5050"/>
        <SolidColorBrush x:Key="DisplayUnits"   Color="#E8C040"/>
        <SolidColorBrush x:Key="PanelBg"        Color="#F5EFE6"/>
        <SolidColorBrush x:Key="PanelStroke"    Color="#D8C9A8"/>
        <SolidColorBrush x:Key="ButtonRed"      Color="#9E2A2B"/>
        <SolidColorBrush x:Key="StatusBg"       Color="#1E1E1E"/>

        <Style x:Key="DisplayValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="22"/>
            <Setter Property="Foreground" Value="{StaticResource DisplayFg}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="Margin" Value="6,2"/>
        </Style>

        <Style x:Key="DisplayLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource DisplayFg}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,2"/>
        </Style>

        <Style x:Key="DisplayUnit" TargetType="TextBlock" BasedOn="{StaticResource DisplayLabel}">
            <Setter Property="Foreground" Value="{StaticResource DisplayUnits}"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="DisplayHeaderText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource DisplayHeader}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="8,4"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonRed}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Application.Resources>
</Application>
