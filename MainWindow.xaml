<Window x:Class="Newton4thGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Newton4thGui.ViewModels"
        Title="Newtons4th PPA5xxx — Remote Console (Serial + LAN)"
        Height="780" Width="1180"
        Background="{StaticResource PanelBg}">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel LastChildFill="True">

        <!-- ==================== Top toolbar: connection ==================== -->
        <!-- Two rows:
               1. Serial (RS232 / USB-CDC): port + baud, plus the Connect / Disconnect
                  buttons that work for whichever transport is currently selected below.
               2. LAN: interface radios + IP + port (for the PPA530 on the bench).
             Both are visible at once so the user can see what's configured without
             flipping between modes; the inactive transport's inputs grey out. -->
        <Border DockPanel.Dock="Top" Background="#FAFAFA"
                BorderBrush="{StaticResource PanelStroke}" BorderThickness="0,0,0,1"
                Padding="10,6">
            <StackPanel>
                <!-- Row 1: serial -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="320"
                              ItemsSource="{Binding AvailablePorts}"
                              SelectedItem="{Binding SelectedPort}"
                              DisplayMemberPath="Display"
                              ToolTip="Pick the COM port for either the RS232 cable or the instrument's native USB port. Both work the same way.">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Setter Property="IsEnabled" Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsLanMode}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>

                    <TextBlock Text="Baud:" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <ComboBox Width="90" SelectedValue="{Binding BaudRate}" SelectedValuePath="Content">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Setter Property="IsEnabled" Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsLanMode}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                        <ComboBoxItem Content="9600"/>
                        <ComboBoxItem Content="19200"/>
                        <ComboBoxItem Content="38400"/>
                        <ComboBoxItem Content="57600"/>
                        <ComboBoxItem Content="115200"/>
                    </ComboBox>

                    <Button Content="Refresh" Margin="6,0,0,0" Padding="10,4"
                            Command="{Binding RefreshPortsCommand}"/>
                    <Button Content="Connect" Margin="6,0,0,0" Padding="14,4"
                            Background="#2D7D46" Foreground="White" FontWeight="Bold"
                            Command="{Binding ConnectCommand}"/>
                    <Button Content="Disconnect" Margin="4,0,0,0" Padding="14,4"
                            Command="{Binding DisconnectCommand}"/>

                    <TextBlock Text="Refresh:" VerticalAlignment="Center" Margin="20,0,4,0"/>
                    <TextBox Width="50" Text="{Binding RefreshHz, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Text="Hz" VerticalAlignment="Center" Margin="4,0,0,0"/>

                    <TextBlock Margin="20,0,0,0" VerticalAlignment="Center"
                               FontFamily="Consolas" FontWeight="Bold"
                               Text="{Binding Identity}"/>
                </StackPanel>

                <!-- Row 2: LAN (PPA530) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,6,0,0">
                    <TextBlock Text="Interface:" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="#444" FontWeight="SemiBold"/>
                    <RadioButton Content="Serial (RS232 / USB)" GroupName="iface"
                                 VerticalAlignment="Center" Margin="0,0,12,0"
                                 IsEnabled="{Binding NotConnected}"
                                 IsChecked="{Binding IsSerialMode, Mode=OneWay}"
                                 Checked="SerialMode_Checked"/>
                    <RadioButton Content="LAN (PPA530)" GroupName="iface"
                                 VerticalAlignment="Center" Margin="0,0,16,0"
                                 IsEnabled="{Binding NotConnected}"
                                 IsChecked="{Binding IsLanMode, Mode=OneWay}"
                                 Checked="LanMode_Checked"/>

                    <TextBlock Text="IP:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="140" VerticalContentAlignment="Center"
                             Text="{Binding LanHost, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding NotConnected}" Value="True"/>
                                            <Condition Binding="{Binding IsLanMode}"   Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="IsEnabled" Value="True"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBlock Text="Port:" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <TextBox Width="60" VerticalContentAlignment="Center"
                             Text="{Binding LanPort, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding NotConnected}" Value="True"/>
                                            <Condition Binding="{Binding IsLanMode}"   Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="IsEnabled" Value="True"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center"
                               Foreground="#888" FontSize="11"
                               Text="(default port 10001 — Lantronix XPort data tunnel, verified on PPA530 115-01543)"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ==================== Setup reminder banner ==================== -->
        <!-- Visible from first launch; greys out once a connection is open so it
             stops competing with live readings. -->
        <Border DockPanel.Dock="Top" Background="#FFF3CD"
                BorderBrush="#E0A800" BorderThickness="0,0,0,1"
                Padding="10,6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding NotConnected}"  Value="True"/>
                                <Condition Binding="{Binding IsSerialMode}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x26A0;" FontSize="14" Foreground="#856404"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Foreground="#856404" VerticalAlignment="Center"
                               FontWeight="Bold">
                        SETUP: both sides must be set to 19200 baud, 8 data bits, no parity, 1 stop bit, no flow control.
                    </TextBlock>
                </StackPanel>
                <TextBlock Foreground="#856404" Margin="22,2,0,0">
                    1. On this laptop &#x2192; set the <Run FontWeight="Bold">Baud</Run> selector above to <Run FontWeight="Bold">19200</Run>.
                </TextBlock>
                <TextBlock Foreground="#856404" Margin="22,0,0,0">
                    2. On the PPA5500 &#x2192; <Run FontWeight="Bold">MENU &#x2192; INTERFACES &#x2192; RS232 &#x2192; baud = 19200</Run>.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- LAN setup banner — analogue of the serial-setup hint, visible only when
             LAN is selected and we're not connected. -->
        <Border DockPanel.Dock="Top" Background="#E7F3FE"
                BorderBrush="#1565C0" BorderThickness="0,0,0,1"
                Padding="10,6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding NotConnected}" Value="True"/>
                                <Condition Binding="{Binding IsLanMode}"   Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F310;" FontSize="14" Foreground="#0D47A1"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Foreground="#0D47A1" VerticalAlignment="Center"
                               FontWeight="Bold">
                        LAN: confirm the PPA530 REMOTE menu shows interface = LAN with the IP and port set above.
                    </TextBlock>
                </StackPanel>
                <TextBlock Foreground="#0D47A1" Margin="22,2,0,0">
                    On the PPA530 &#x2192; <Run FontWeight="Bold">MENU &#x2192; INTERFACES &#x2192; LAN</Run>, IP = <Run FontWeight="Bold" Text="{Binding LanHost, Mode=OneWay}"/>, port = <Run FontWeight="Bold" Text="{Binding LanPort, Mode=OneWay}"/>.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ==================== Setup reminder banner ==================== -->
        <!-- Visible from first launch; greys out once a connection is open so it
             stops competing with live readings. -->
        <Border DockPanel.Dock="Top" Background="#FFF3CD"
                BorderBrush="#E0A800" BorderThickness="0,0,0,1"
                Padding="10,6"
                Visibility="{Binding NotConnected, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x26A0;" FontSize="14" Foreground="#856404"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Foreground="#856404" VerticalAlignment="Center"
                               FontWeight="Bold">
                        SETUP: both sides must be set to 19200 baud, 8 data bits, no parity, 1 stop bit, no flow control.
                    </TextBlock>
                </StackPanel>
                <TextBlock Foreground="#856404" Margin="22,2,0,0">
                    1. On this laptop &#x2192; set the <Run FontWeight="Bold">Baud</Run> selector above to <Run FontWeight="Bold">19200</Run>.
                </TextBlock>
                <TextBlock Foreground="#856404" Margin="22,0,0,0">
                    2. On the PPA5500 &#x2192; <Run FontWeight="Bold">MENU &#x2192; INTERFACES &#x2192; RS232 &#x2192; baud = 19200</Run>.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ==================== Bottom status bar ==================== -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource StatusBg}"
                Padding="10,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Foreground="#FFD23F" FontFamily="Consolas"
                           Text="{Binding Status}"/>
                <TextBlock Grid.Column="1" Foreground="#9090A0" FontFamily="Consolas"
                           Text="{Binding LogStatus}"/>
            </Grid>
        </Border>

        <!-- ==================== Tabs ==================== -->
        <TabControl Margin="6">

            <!-- ==================== Power Analyzer ==================== -->
            <TabItem Header="Power Analyzer">
                <Border Margin="6" Background="{StaticResource DisplayBg}" CornerRadius="4" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header bar -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource DisplayHeaderText}"
                                       Text="POWER ANALYZER     coupling: ac     bandwidth: wide"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource DisplayLabel}"
                                       Text="{Binding Status}"/>
                        </Grid>

                        <!-- Phase grid: matches PPA5500 LCD exactly -->
                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- col headers -->
                                <RowDefinition Height="Auto"/>  <!-- watts -->
                                <RowDefinition Height="Auto"/>  <!-- VA -->
                                <RowDefinition Height="Auto"/>  <!-- VAr -->
                                <RowDefinition Height="Auto"/>  <!-- pf -->
                                <RowDefinition Height="Auto"/>  <!-- rms V -->
                                <RowDefinition Height="Auto"/>  <!-- rms A -->
                                <RowDefinition Height="Auto"/>  <!-- frequency -->
                                <RowDefinition Height="Auto"/>  <!-- dc % -->
                                <RowDefinition Height="Auto"/>  <!-- dc watts -->
                                <RowDefinition Height="Auto"/>  <!-- V ph-ph -->
                                <RowDefinition Height="Auto"/>  <!-- V THD -->
                                <RowDefinition Height="Auto"/>  <!-- I THD -->
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <!-- Column headers -->
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="phase 1" Style="{StaticResource DisplayLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="phase 2" Style="{StaticResource DisplayLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="phase 3" Style="{StaticResource DisplayLabel}" HorizontalAlignment="Center"/>

                            <!-- watts -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="watts"     Style="{StaticResource DisplayLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Phase1.WattsText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Phase2.WattsText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Phase3.WattsText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="4" Text="W"         Style="{StaticResource DisplayUnit}"/>

                            <!-- VA -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="VA"        Style="{StaticResource DisplayLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Phase1.VAText}"    Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding Phase2.VAText}"    Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding Phase3.VAText}"    Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="4" Text="VA"        Style="{StaticResource DisplayUnit}"/>

                            <!-- VAr -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="VAr"       Style="{StaticResource DisplayLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Phase1.VArText}"   Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding Phase2.VArText}"   Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding Phase3.VArText}"   Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="4" Text="VAr"       Style="{StaticResource DisplayUnit}"/>

                            <!-- pf -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="pf"        Style="{StaticResource DisplayLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Phase1.PfText}"    Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding Phase2.PfText}"    Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="4" Grid.Column="3" Text="{Binding Phase3.PfText}"    Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="4" Grid.Column="4" Text=""          Style="{StaticResource DisplayUnit}"/>

                            <!-- rms V -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="rms"       Style="{StaticResource DisplayLabel}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Phase1.VRmsText}"  Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding Phase2.VRmsText}"  Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="5" Grid.Column="3" Text="{Binding Phase3.VRmsText}"  Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="5" Grid.Column="4" Text="V"         Style="{StaticResource DisplayUnit}"/>

                            <!-- rms A -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="rms"       Style="{StaticResource DisplayLabel}"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Phase1.IRmsText}"  Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding Phase2.IRmsText}"  Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="6" Grid.Column="3" Text="{Binding Phase3.IRmsText}"  Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="6" Grid.Column="4" Text="A"         Style="{StaticResource DisplayUnit}"/>

                            <!-- frequency (single value, shown in phase 1 column) -->
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="frequency" Style="{StaticResource DisplayLabel}"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding FrequencyText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="7" Grid.Column="4" Text="Hz"        Style="{StaticResource DisplayUnit}"/>

                            <!-- dc % -->
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="dc watts"  Style="{StaticResource DisplayLabel}"/>
                            <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding Phase1.DcPctText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="8" Grid.Column="2" Text="{Binding Phase2.DcPctText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="8" Grid.Column="3" Text="{Binding Phase3.DcPctText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="8" Grid.Column="4" Text="%"         Style="{StaticResource DisplayUnit}"/>

                            <!-- dc watts -->
                            <TextBlock Grid.Row="9" Grid.Column="0" Text="dc watts"  Style="{StaticResource DisplayLabel}"/>
                            <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding Phase1.WattsDcText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="9" Grid.Column="2" Text="{Binding Phase2.WattsDcText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="9" Grid.Column="3" Text="{Binding Phase3.WattsDcText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="9" Grid.Column="4" Text="W"         Style="{StaticResource DisplayUnit}"/>

                            <!-- V ph-ph -->
                            <TextBlock Grid.Row="10" Grid.Column="0" Text="V ph-ph"  Style="{StaticResource DisplayLabel}"/>
                            <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding Phase1.VPhPhText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="10" Grid.Column="2" Text="{Binding Phase2.VPhPhText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="10" Grid.Column="3" Text="{Binding Phase3.VPhPhText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="10" Grid.Column="4" Text="V"        Style="{StaticResource DisplayUnit}"/>

                            <!-- V THD -->
                            <TextBlock Grid.Row="11" Grid.Column="0" Text="V THD"    Style="{StaticResource DisplayLabel}"/>
                            <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding Phase1.VThdText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="11" Grid.Column="2" Text="{Binding Phase2.VThdText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="11" Grid.Column="3" Text="{Binding Phase3.VThdText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="11" Grid.Column="4" Text=""         Style="{StaticResource DisplayUnit}"/>

                            <!-- I THD -->
                            <TextBlock Grid.Row="12" Grid.Column="0" Text="I THD"    Style="{StaticResource DisplayLabel}"/>
                            <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding Phase1.IThdText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="12" Grid.Column="2" Text="{Binding Phase2.IThdText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="12" Grid.Column="3" Text="{Binding Phase3.IThdText}" Style="{StaticResource DisplayValue}"/>
                            <TextBlock Grid.Row="12" Grid.Column="4" Text=""         Style="{StaticResource DisplayUnit}"/>
                        </Grid>

                        <!-- Lab conditions strip: Rotronic ambient T / RH (env probe) -->
                        <Border Grid.Row="2" Margin="0,10,0,0" Padding="10,6"
                                Background="#0E1620" BorderBrush="#243142" BorderThickness="1" CornerRadius="3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="lab" Style="{StaticResource DisplayLabel}" VerticalAlignment="Center"/>
                                <TextBlock Text="T"   Style="{StaticResource DisplayLabel}" Margin="20,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TemperatureText}" Style="{StaticResource DisplayValue}" VerticalAlignment="Center"/>
                                <TextBlock Text="°C"  Style="{StaticResource DisplayUnit}"  Margin="4,0,0,0"  VerticalAlignment="Center"/>
                                <TextBlock Text="RH"  Style="{StaticResource DisplayLabel}" Margin="30,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding HumidityText}"    Style="{StaticResource DisplayValue}" VerticalAlignment="Center"/>
                                <TextBlock Text="%"   Style="{StaticResource DisplayUnit}"  Margin="4,0,0,0"  VerticalAlignment="Center"/>
                                <TextBlock Margin="40,0,0,0" VerticalAlignment="Center"
                                           Foreground="#8090A8" FontFamily="Consolas" FontSize="11"
                                           Text="{Binding RotronicDeviceLabel}"/>
                                <TextBlock Margin="14,0,0,0" VerticalAlignment="Center"
                                           Foreground="#FFCC66" FontFamily="Consolas" FontSize="11"
                                           Text="{Binding RotronicStatus}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>


            <!-- ==================== CSV Data Logger ==================== -->
            <TabItem Header="Data Logger (CSV)">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- controls panel -->
                        <RowDefinition Height="*"/>     <!-- live rows -->
                    </Grid.RowDefinitions>

                    <!-- Settings + Start/Stop -->
                    <Border Grid.Row="0" Background="#FAFAFA"
                            BorderBrush="{StaticResource PanelStroke}" BorderThickness="1"
                            CornerRadius="3" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Sample interval:" VerticalAlignment="Center" Margin="0,4"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                                <TextBox Width="80" VerticalContentAlignment="Center"
                                         Text="{Binding LogIntervalValue, UpdateSourceTrigger=PropertyChanged}"/>
                                <ComboBox Width="100" Margin="6,0,0,0" SelectedValue="{Binding LogIntervalUnit}"
                                          SelectedValuePath="Content">
                                    <ComboBoxItem Content="Minutes"/>
                                    <ComboBoxItem Content="Hours"/>
                                </ComboBox>
                                <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Foreground="#666"
                                           Text="(suitable for runs of weeks — each row is flushed to disk)"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Output folder:" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox    Grid.Row="1" Grid.Column="1" VerticalContentAlignment="Center"
                                        Text="{Binding LogFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Active files:" VerticalAlignment="Center" Margin="0,4"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="{Binding LogFile}"  FontFamily="Consolas" Foreground="#444" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding JsonFile}" FontFamily="Consolas" Foreground="#666" TextTrimming="CharacterEllipsis" FontSize="11"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Start logging" Style="{StaticResource ActionButton}"
                                        Background="#2D7D46"
                                        Command="{Binding StartLoggingCommand}"/>
                                <Button Content="Stop"  Style="{StaticResource ActionButton}"
                                        Command="{Binding StopLoggingCommand}"/>
                                <Button Content="Export to XLSX" Style="{StaticResource ActionButton}"
                                        Background="#1565C0"
                                        Command="{Binding ExportXlsxCommand}"/>
                                <TextBlock Margin="20,0,0,0" VerticalAlignment="Center">
                                    <Run Text="Rows captured:" Foreground="#555"/>
                                    <Run Text="{Binding RowsWritten}" FontWeight="Bold"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Live tail of CSV rows -->
                    <Border Grid.Row="1" Margin="0,8,0,0" CornerRadius="3"
                            Background="{StaticResource DisplayBg}" Padding="2">
                        <DataGrid ItemsSource="{Binding LoggedRows}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#222"
                                  RowBackground="{StaticResource DisplayBg}"
                                  AlternatingRowBackground="#0F0F0F"
                                  Foreground="{StaticResource DisplayFg}"
                                  Background="{StaticResource DisplayBg}"
                                  BorderThickness="0"
                                  FontFamily="Consolas"
                                  FontSize="13"
                                  EnableRowVirtualization="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  Loaded="LoggedRowsGrid_Loaded"
                                  Name="LoggedRowsGrid">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#1A1A1A"/>
                                    <Setter Property="Foreground" Value="#FFCC66"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Padding" Value="6,3"/>
                                    <Setter Property="BorderBrush" Value="#333"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="date / time" Binding="{Binding TimeText}"   Width="160"/>
                                <DataGridTextColumn Header="T"           Binding="{Binding TempText}"   Width="80"/>
                                <DataGridTextColumn Header="RH"          Binding="{Binding RhText}"     Width="70"/>
                                <DataGridTextColumn Header="freq"        Binding="{Binding FreqText}"   Width="80"/>
                                <DataGridTextColumn Header="ch1 V"       Binding="{Binding Ch1VText}"   Width="100"/>
                                <DataGridTextColumn Header="ch2 V"       Binding="{Binding Ch2VText}"   Width="100"/>
                                <DataGridTextColumn Header="ch3 V"       Binding="{Binding Ch3VText}"   Width="100"/>
                                <DataGridTextColumn Header="ch1 A"       Binding="{Binding Ch1AText}"   Width="100"/>
                                <DataGridTextColumn Header="ch2 A"       Binding="{Binding Ch2AText}"   Width="100"/>
                                <DataGridTextColumn Header="ch3 A"       Binding="{Binding Ch3AText}"   Width="100"/>
                                <DataGridTextColumn Header="ch1 W"       Binding="{Binding Ch1WText}"   Width="100"/>
                                <DataGridTextColumn Header="ch2 W"       Binding="{Binding Ch2WText}"   Width="100"/>
                                <DataGridTextColumn Header="ch3 W"       Binding="{Binding Ch3WText}"   Width="100"/>
                                <DataGridTextColumn Header="ch1 pf"      Binding="{Binding Ch1PfText}"  Width="80"/>
                                <DataGridTextColumn Header="ch2 pf"      Binding="{Binding Ch2PfText}"  Width="80"/>
                                <DataGridTextColumn Header="ch3 pf"      Binding="{Binding Ch3PfText}"  Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
